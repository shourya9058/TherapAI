# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/therapai?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# Email Configuration
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password
EMAIL_FROM=TherapAI <noreply@therapai.com>

# Client URL (for email links and CORS)
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-frontend.vercel.app

# File Upload (if needed)
FILE_UPLOAD_PATH=./uploads
MAX_FILE_UPLOAD=1000000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=15*60*1000 // 15 minutes
RATE_LIMIT_MAX=100 // 100 requests per window
